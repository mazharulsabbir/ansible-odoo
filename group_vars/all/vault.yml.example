---
# ============================================================================
# ANSIBLE VAULT - SENSITIVE VARIABLES (EXAMPLE)
# ============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to vault.yml:
#    cp group_vars/all/vault.yml.example group_vars/all/vault.yml
#
# 2. Replace ALL placeholder values with your actual secrets
#
# 3. Encrypt the vault.yml file:
#    ansible-vault encrypt group_vars/all/vault.yml
#
# 4. Run playbooks with vault password:
#    ansible-playbook site.yml --ask-vault-pass
#    OR
#    ansible-playbook site.yml --vault-password-file .vault_pass
#
# To edit encrypted file: ansible-vault edit group_vars/all/vault.yml
# To view encrypted file: ansible-vault view group_vars/all/vault.yml
#
# Generate strong passwords using:
#   openssl rand -base64 32
#   pwgen -s 32 1
#
# ============================================================================

# ── Server Connection ───────────────────────────────────────────────────────
# Server IP address or hostname
vault_server_host: "YOUR_SERVER_IP"

# SSH password for server authentication (if not using SSH keys)
# Leave empty if using SSH key authentication
vault_ssh_password: "YOUR_SSH_PASSWORD"

# Sudo password for privilege escalation (if different from SSH password)
# Leave empty if same as SSH password or using passwordless sudo
vault_sudo_password: "YOUR_SUDO_PASSWORD"

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# PostgreSQL database password for the 'odoo' user
# Used for database authentication in odoo.conf and PostgreSQL setup
vault_pg_password: "CHANGE_ME_GENERATE_STRONG_PASSWORD"

# ── Odoo ────────────────────────────────────────────────────────────────────
# Odoo master password (admin_passwd in odoo.conf)
# Required to create/duplicate/delete databases via web interface
# Set a very strong password or disable database manager in production
vault_odoo_admin_passwd: "CHANGE_ME_GENERATE_STRONG_PASSWORD"

# ── Domain & SSL ────────────────────────────────────────────────────────────
# Your domain name for Odoo (used in Nginx configuration)
vault_domain_name: "odoo.yourdomain.com"

# Email for Let's Encrypt SSL certificate registration
vault_letsencrypt_email: "admin@yourdomain.com"

# ── Git / Private Addon Repositories ────────────────────────────────────────
# GitHub Personal Access Token used to clone PRIVATE custom addon repos over
# HTTPS. Only repos marked `private: true` in custom_addons_repos use it.
# Create a fine-grained or classic PAT with "repo" (read) scope at:
#   https://github.com/settings/tokens
# Leave empty if all your custom_addons_repos are public.
vault_github_token: ""